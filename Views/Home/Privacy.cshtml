@model IReadOnlyList<agentmodedemo.Models.EmployeeRecord>

@{
    ViewData["Title"] = "Employee Directory";
}

<style>
    .employee-page {
        background: linear-gradient(135deg, #f7f9ff, #eef6ff);
        border: 1px solid #dce9ff;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 12px 30px rgba(38, 78, 145, 0.12);
    }

    .employee-title {
        color: #1d3557;
        font-weight: 700;
        letter-spacing: 0.5px;
        margin-bottom: 0.25rem;
    }

    .employee-subtitle {
        color: #355070;
        margin-bottom: 1.25rem;
    }

    .search-row {
        margin-bottom: 1rem;
    }

    .employee-table {
        overflow: hidden;
        border-radius: 12px;
        background: #ffffff;
    }

    .employee-table table {
        margin-bottom: 0;
    }

    .employee-table thead th {
        background: #1d3557;
        color: #ffffff;
        border: none;
    }

    .employee-table tbody tr:nth-child(odd) {
        background: #f9fcff;
    }

    .employee-table tbody tr:hover {
        background: #e6f1ff;
    }
</style>

<section class="employee-page">
    <h1 class="employee-title">@ViewData["Title"]</h1>
    <p class="employee-subtitle">Select an employee to view complete details.</p>

    <div class="search-row">
        <label for="employeeSearch" class="form-label fw-semibold">Search by name</label>
        <input
            id="employeeSearch"
            type="text"
            class="form-control"
            placeholder="Type a first or last name..."
            autocomplete="off"
        />
    </div>

    <div class="table-responsive employee-table">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < Model.Count; i++)
                {
                    var employee = Model[i];
                    <tr>
                        <td class="employee-name">@employee.FirstName @employee.LastName</td>
                        <td>@employee.Department</td>
                        <td>
                            <a asp-action="EmployeeDetails" asp-route-id="@i" class="btn btn-sm btn-outline-primary">
                                View Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<script>
    (function () {
        const searchInput = document.getElementById("employeeSearch");
        if (!searchInput) {
            return;
        }

        const rows = Array.from(document.querySelectorAll(".employee-table tbody tr"));

        searchInput.addEventListener("input", function () {
            const term = searchInput.value.trim().toLowerCase();

            rows.forEach(function (row) {
                const nameCell = row.querySelector(".employee-name");
                const employeeName = (nameCell?.textContent ?? "").toLowerCase();
                const isMatch = employeeName.includes(term);
                row.style.display = isMatch ? "" : "none";
            });
        });
    })();
</script>
