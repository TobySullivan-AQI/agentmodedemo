@model IReadOnlyList<agentmodedemo.Models.EmployeeRecord>

@{
    ViewData["Title"] = "Employee Directory";
}

<style>
    .employee-page {
        background: linear-gradient(135deg, #f7f9ff, #eef6ff);
        border: 1px solid #dce9ff;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 12px 30px rgba(38, 78, 145, 0.12);
    }

    .employee-title {
        color: #1d3557;
        font-weight: 700;
        letter-spacing: 0.5px;
        margin-bottom: 0.25rem;
    }

    .employee-subtitle {
        color: #355070;
        margin-bottom: 1.25rem;
    }

    .employee-table {
        overflow: hidden;
        border-radius: 12px;
        background: #ffffff;
    }

    .employee-table table {
        margin-bottom: 0;
    }

    .employee-table thead th {
        background: #1d3557;
        color: #ffffff;
        border: none;
    }

    .employee-table tbody tr:nth-child(odd) {
        background: #f9fcff;
    }

    .employee-table tbody tr:hover {
        background: #e6f1ff;
    }
</style>

<section class="employee-page">
    <h1 class="employee-title">@ViewData["Title"]</h1>
    <p class="employee-subtitle">Sample employee records loaded from sampledata.json</p>

    <div class="table-responsive employee-table">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Hiring Date</th>
                    <th>Department</th>
                    <th>Job Title</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var employee in Model)
                {
                    <tr>
                        <td>@employee.FirstName</td>
                        <td>@employee.LastName</td>
                        <td>@employee.HiringDate.ToString("yyyy-MM-dd")</td>
                        <td>@employee.Department</td>
                        <td>@employee.JobTitle</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
